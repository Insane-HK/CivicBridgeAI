# CivicBridge AI — Frontend Environment Variables
# Copy this file to .env and fill in your values

# Your deployed API Gateway endpoint URL
# Get this after running: sam deploy --guided (or deploying Lambda manually)
VITE_API_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/prod/analyze

# If this is not set, the app runs in Demo Mode (uses built-in sample data)
